+                        df = ex.get_ohlc(symbol=sym, timeframe=tf, limit=1000, since_ms=cur)
+                        if df is None or df.empty:
+                            break
+                        chunks.append(df)
+                        last_dt = pd.to_datetime(df["datetime"].iloc[-1])
+                        nxt = int(last_dt.timestamp() * 1000) + 1
+                        if nxt <= cur:
+                            break
+                        cur = nxt
+                        if len(df) < 1000:
+                            break
+                    if not chunks:
