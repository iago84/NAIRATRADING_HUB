---def calculate_sl_tp(row, direction, rr=2.0):
---    atr = row['atr']
---    price = row['close']
---
---    if direction == "BUY":
---        sl = price - atr * 1.5
---        tp = price + (price - sl) * rr
---
---    elif direction == "SELL":
---        sl = price + atr * 1.5
---        tp = price - (sl - price) * rr
---
---    else:
---        return None, None
---
---    return sl, tp
